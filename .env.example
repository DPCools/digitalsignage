# Database
# In Docker Compose the host is the service name (postgres); locally use localhost.
DATABASE_URL=postgresql://signflow:secret@localhost:5432/signflow
TENANT_DATABASE_URL=postgresql://signflow:secret@localhost:5432/signflow

# Auth (NextAuth v5 — AUTH_SECRET replaces NEXTAUTH_SECRET; both kept for compatibility)
AUTH_SECRET=change-me-minimum-32-characters-long
AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-minimum-32-characters-long
NEXTAUTH_URL=http://localhost:3000

# MinIO
# In Docker Compose set MINIO_ENDPOINT=minio (service name); locally use localhost or your LAN IP.
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=signflow
MINIO_SECRET_KEY=signflow-secret
MINIO_BUCKET=signflow-assets
MINIO_PUBLIC_URL=http://localhost:9000

# Redis
REDIS_URL=redis://localhost:6379

# Socket.io
SOCKET_SECRET=change-me-socket-secret

# Player API auth (HMAC-SHA256 key for player device tokens)
PLAYER_TOKEN_SECRET=change-me-player-token-secret

# Player
# NOTE: these are inlined into the client bundle at build time (Next.js), not read at
# container runtime. When deploying via docker-compose, they must be set here BEFORE
# `docker compose up -d --build` so they reach the admin/player build args.
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Web Push (VAPID) — required for push notifications feature
# Generate keys: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(JSON.stringify(k,null,2))"
VAPID_SUBJECT=mailto:admin@yourdomain.com
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
# Same build-time caveat as above — must equal VAPID_PUBLIC_KEY.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# SMTP (used for invite/alert/screen-offline emails — Email Templates and
# Recipient Lists are still configured in the admin UI, only the mail server
# connection itself is hardcoded here, not per-org configurable)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=alerts@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=alerts@example.com
SMTP_FROM_NAME=SignFlow

# External
OPENWEATHERMAP_API_KEY=your-key-here

# Features
CONTENT_APPROVAL_REQUIRED=false
