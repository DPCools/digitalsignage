{
  "name": "@signflow/db",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:generate": "prisma generate --schema ./prisma/public.prisma && prisma generate --schema ./prisma/tenant.prisma",
    "db:migrate:public": "prisma migrate deploy --schema ./prisma/public.prisma",
    "db:migrate:public:dev": "prisma migrate dev --schema ./prisma/public.prisma",
    "db:migrate:tenant": "tsx ./src/apply-tenant-migrations.ts",
    "db:seed": "tsx ./prisma/seed.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.11.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "pg": "^8.21.0"
  }
}
