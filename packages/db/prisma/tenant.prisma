generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/tenant"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("TENANT_DATABASE_URL")
}

model Screen {
  id                String           @id @default(cuid())
  name              String
  uniqueCode        String           @unique
  // Opaque bearer token issued at pairing time, verified by DB lookup rather
  // than recomputed HMAC — so rotating/losing PLAYER_TOKEN_SECRET never
  // invalidates devices that have already paired.
  authToken         String?          @unique
  groupId           String?
  group             ScreenGroup?     @relation(fields: [groupId], references: [id])
  orientation       Orientation      @default(LANDSCAPE)
  resolution        String?
  tags              String[]
  isOnline          Boolean          @default(false)
  lastHeartbeat     DateTime?
  lastSnapshot      String?
  currentPlaylistId String?
  currentPlaylist   Playlist?        @relation("CurrentScreenPlaylist", fields: [currentPlaylistId], references: [id])
  heartbeats        ScreenHeartbeat[]
  impressions       Impression[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([lastHeartbeat(sort: Desc)])
  @@index([currentPlaylistId])
  @@index([groupId])
}

model ScreenGroup {
  id                String    @id @default(cuid())
  name              String
  type              GroupType @default(OTHER)
  location          String?
  description       String?
  defaultPlaylistId String?
  defaultPlaylist   Playlist? @relation("GroupDefaultPlaylist", fields: [defaultPlaylistId], references: [id])
  screens           Screen[]
  audioBridges      AudioBridge[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model AudioBridge {
  id        String      @id @default(cuid())
  name      String
  groupId   String
  group     ScreenGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  host      String
  port      Int         @default(80)
  username  String
  password  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([groupId])
}

model ContentItem {
  id            String        @id @default(cuid())
  name          String
  type          ContentType
  url           String
  thumbnailUrl  String?
  mimeType      String?
  fileSize      Int?
  duration      Int?
  templateId    String?
  template      Template?     @relation(fields: [templateId], references: [id])
  metadata      Json?
  status        ContentStatus @default(PENDING)
  approvedBy    String?
  uploadedBy    String
  expiresAt     DateTime?
  playlistItems PlaylistItem[]
  impressions   Impression[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([expiresAt])
  @@index([type])
  @@index([createdAt(sort: Desc)])
}

model Template {
  id           String        @id @default(cuid())
  name         String
  html         String
  css          String?
  variables    Json
  thumbnail    String?
  createdBy    String
  contentItems ContentItem[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Playlist {
  id             String         @id @default(cuid())
  name           String
  description    String?
  isDefault      Boolean        @default(false)
  // Grid layout: preset id (e.g. "2x2"); NULL = legacy 4-zone layout (main/ticker/clock/weather)
  layoutPreset   String?
  // Per-cell mode overrides: [{ "cellId": "a", "mode": "FIXED" }, ...]
  cellConfig     Json?
  items          PlaylistItem[]
  schedules      Schedule[]
  currentScreens  Screen[]       @relation("CurrentScreenPlaylist")
  defaultForGroups ScreenGroup[] @relation("GroupDefaultPlaylist")
  createdBy      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model PlaylistItem {
  id            String         @id @default(cuid())
  playlistId    String
  playlist      Playlist       @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  contentItemId String
  contentItem   ContentItem    @relation(fields: [contentItemId], references: [id])
  position      Int
  duration      Int
  transition    TransitionType @default(FADE)
  zone          String         @default("main")
  createdAt     DateTime       @default(now())

  @@unique([playlistId, position])
}

model Schedule {
  id          String         @id @default(cuid())
  playlistId  String
  playlist    Playlist       @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  name        String?
  startDate   DateTime
  endDate     DateTime?
  startTime   String?
  endTime     String?
  recurrence  RecurrenceType @default(ONCE)
  daysOfWeek  Int[]
  screenIds   String[]
  groupIds    String[]
  priority    Int            @default(0)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([playlistId])
  @@index([isActive])
}

model EmergencyAlert {
  id              String    @id @default(cuid())
  title           String
  message         String
  backgroundColor String    @default("#FF0000")
  textColor       String    @default("#FFFFFF")
  /// Loose reference to AlertTemplate.id. No FK enforced — intentional so that
  /// deleting a template does not cascade-delete historical alert records.
  /// Service layer must handle the case where the referenced template no longer exists.
  templateId      String?
  screenIds       String[]
  /// RecipientList ids emailed when this alert is triggered. No FK — deleting a
  /// list must not cascade-delete historical alerts; stale ids are skipped at send.
  recipientListIds String[]
  isActive        Boolean        @default(true)
  severity        AlertSeverity  @default(EMERGENCY)
  soundUrl        String?
  soundRepeat     Int            @default(30)
  expiresAt       DateTime?
  createdBy       String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([isActive])
}

/// A named, reusable set of email addresses that can be assigned to alerts and to
/// the screen-offline email template.
model RecipientList {
  id        String   @id @default(cuid())
  name      String
  emails    String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// One editable email template per notification event. Seeded on first read.
/// `recipientListIds` is only meaningful for the SCREEN_OFFLINE event (its global
/// recipients); ALERT_TRIGGERED picks lists per-alert and USER_INVITED emails the
/// invitee directly.
model EmailTemplate {
  id               String   @id @default(cuid())
  event            String   @unique
  enabled          Boolean  @default(true)
  subject          String
  bodyHtml         String
  recipientListIds String[]
  updatedAt        DateTime @updatedAt
}

model AlertTemplate {
  id                String        @id @default(cuid())
  name              String
  title             String
  message           String
  backgroundColor   String        @default("#FF0000")
  textColor         String        @default("#FFFFFF")
  targetType        TargetType    @default(ALL)
  targetGroupIds    String[]
  targetScreenIds   String[]
  /// RecipientList ids emailed when an alert created from this template triggers.
  recipientListIds  String[]
  autoExpireMinutes Int?
  severity          AlertSeverity @default(EMERGENCY)
  soundUrl          String?
  soundRepeat       Int           @default(30)
  createdBy         String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model AlertSound {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  url       String
  createdBy String
  createdAt DateTime @default(now())
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyPrefix  String    @unique
  keyHash    String    @unique
  createdBy  String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model ScreenHeartbeat {
  id         String   @id @default(cuid())
  screenId   String
  screen     Screen   @relation(fields: [screenId], references: [id], onDelete: Cascade)
  timestamp  DateTime @default(now())
  playlistId String?
  contentId  String?

  @@index([screenId, timestamp(sort: Desc)])
}

model Impression {
  id            String      @id @default(cuid())
  contentItemId String
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id])
  screenId      String
  screen        Screen      @relation(fields: [screenId], references: [id])
  playedAt      DateTime    @default(now())
  durationMs    Int

  @@index([playedAt(sort: Desc)])
  @@index([contentItemId])
  @@index([screenId])
}

model OrgSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  actorId    String
  actorName  String
  targetId   String?
  targetName String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

enum GroupType {
  SITE
  LOCATION
  DEPARTMENT
  OTHER
}

enum Orientation {
  LANDSCAPE
  PORTRAIT
}

enum ContentType {
  IMAGE
  VIDEO
  HTML_TEMPLATE
  RSS_FEED
  PDF
  WEB_PAGE
  CCTV_GRID
}

enum ContentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransitionType {
  FADE
  SLIDE_LEFT
  SLIDE_RIGHT
  ZOOM
  NONE
}

enum RecurrenceType {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
}

enum TargetType {
  ALL
  GROUPS
  SCREENS
}

enum AlertSeverity {
  EMERGENCY
  WARNING
  INFO
}
