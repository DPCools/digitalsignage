# Web Push (VAPID) — required for push notifications feature
# Generate keys: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(JSON.stringify(k,null,2))"
VAPID_SUBJECT=mailto:admin@yourdomain.com
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
# IMPORTANT: NEXT_PUBLIC_VAPID_PUBLIC_KEY must be set at BUILD TIME (Next.js inlines it).
# Set it to the same value as VAPID_PUBLIC_KEY.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
